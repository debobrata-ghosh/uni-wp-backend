#
# Repo policy: track ONLY custom themes + plugins.
# Everything else (WP core, uploads, backups, configs) stays out of git.
#

# Ignore everything by default
/*

# Keep git + GitHub workflow/config files
!/.gitignore
!/.github/
!/.github/**

# Keep documentation if you want it in repo
!/README.md
!/docs/
!/docs/**

# Allow ONLY these WordPress folders to be tracked
!/wp-content/
/wp-content/*
!/wp-content/themes/
!/wp-content/themes/**
!/wp-content/plugins/
!/wp-content/plugins/**

# --- Uploads / caches / generated ---
/wp-content/uploads/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backups/

# All-in-One WP Migration backups (VERY large .wpress)
/wp-content/ai1wm-backups/

# Logs
/wp-content/debug.log
*.log

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Node / build
node_modules/
dist/
build/

# Env / secrets (never commit)
.env
.env.*

